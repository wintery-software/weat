generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id         String               @id @default(uuid())
  placeId    String               @unique @map("place_id")
  name       String
  altName    String?              @map("alt_name")
  address    String
  price      Int?
  rating     Float?
  images     String[]
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")
  categories RestaurantCategory[]
  items      RestaurantItem[]

  @@map("restaurants")
}

model RestaurantItem {
  id           String     @id @default(uuid())
  restaurantId String     @map("restaurant_id")
  name         String
  altName      String?    @map("alt_name")
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  image        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([name, altName, price])
  @@map("restaurant_items")
}

model Category {
  id          String               @id @default(uuid())
  name        String               @unique
  restaurants RestaurantCategory[]

  @@map("categories")
}

model RestaurantCategory {
  restaurantId String     @map("restaurant_id")
  categoryId   String     @map("category_id")
  category     Category   @relation(fields: [categoryId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@id([restaurantId, categoryId])
  @@map("restaurants_categories")
}
